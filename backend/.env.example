# Backend (NestJS) environment example
#
# Copy this file to `.env` inside `backend/` and fill in values.

# HTTP server
PORT=4000

# Postgres connection (Supabase, Neon, or other)
DATABASE_URL=postgres://user:password@host:5432/laura

# LLM provider keys
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=your-gemini-model
GEMINI_EMBEDDING_MODEL=your-gemini-embedding-model
GEMINI_EMBEDDING_DIMENSION=your-gemini-embedding-dimension

# Google OAuth (Gmail drafts + Calendar events) — see docs/oauth-google-setup.md
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match an "Authorized redirect URI" in Google Cloud Console (backend URL, not Next.js)
GOOGLE_REDIRECT_URI=http://localhost:4000/integrations/google/callback
# Where users land after OAuth (your Next.js app)
FRONTEND_URL=http://localhost:3000
# Optional override (defaults to Gmail compose + Calendar events + calendar list read)
# GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/calendar.calendarlist.readonly

# Set to 1 to print verbose calendar list debug logs in the backend terminal
# DEBUG_CALENDAR=1

# Stage-1 LLM intent classification (two-stage classify-then-chat). Enabled by default.
# Set false/0 to disable classification + LLM intent routing.
# USE_LLM_INTENT=true

# When USE_LLM_INTENT=true, log LLM intent classification in dev (debug). Set false to silence.
# INTENT_SHADOW_LOG=true

# Route calendar list via Stage-1 (enabled by default when USE_LLM_INTENT is on).
# Set false/0 to disable only calendar list routing.
# INTENT_ROUTE_CALENDAR_LIST=true

# Route calendar create/update/delete via Stage-1 (enabled by default when USE_LLM_INTENT is on).
# Set false/0 to disable only calendar mutation routing.
# INTENT_ROUTE_CALENDAR_MUTATIONS=true

# Route email draft / pending send / revise via Stage-1 (enabled by default when USE_LLM_INTENT is on).
# Set false/0 to disable only email routing.
# INTENT_ROUTE_EMAIL=true

# When tool routing is enabled, intents below this confidence skip tool execution.
# Range: 0.0-1.0 (default 0.6).
# INTENT_TOOL_MIN_CONFIDENCE=0.6

