# Root-level environment example for laura

# Shared secrets / configuration used by both frontend and backend.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Postgres connection (Supabase, Neon, or other)
DATABASE_URL=postgres://user:password@host:5432/laura

# LLM provider keys
GEMINI_API_KEY=your-gemini-api-key

# OAuth credentials (for email + calendar providers)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

